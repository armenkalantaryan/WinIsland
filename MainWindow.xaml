<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinIsland.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <!-- Define Storyboards for animations -->
        <Grid.Resources>
            <!-- Entrance Animation -->
            <Storyboard x:Name="EntranceStoryboard">
                <DoubleAnimation Storyboard.TargetName="Island" 
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1" Duration="0:0:0.3"/>
                <DoubleAnimation Storyboard.TargetName="Island" 
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                From="-20" To="0" Duration="0:0:0.3"/>
            </Storyboard>
        </Grid.Resources>

        <!-- Dynamic Island Container -->
        <Border x:Name="Island"
                Width="260"
                Height="80"
                CornerRadius="40"
                Background="#1A1A1A"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                PointerEntered="Island_PointerEntered"
                PointerExited="Island_PointerExited"
                PointerPressed="Island_PointerPressed"
                ManipulationMode="All"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">

            <Border.RenderTransform>
                <TranslateTransform Y="-20"/>
            </Border.RenderTransform>

            <!-- Shadow effect simulation -->
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <Grid>
                <!-- Compact State (Default) -->
                <StackPanel x:Name="CompactState" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Spacing="12"
                           Padding="20,12">
                    <TextBlock x:Name="CompactIcon" 
                               Text="●" 
                               Foreground="#00D084" 
                               FontSize="8" 
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="CompactText" 
                               Text="WinIsland" 
                               Foreground="White" 
                               FontSize="13" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Expanded State (Interactive) -->
                <ScrollViewer x:Name="ExpandedState" 
                             Visibility="Collapsed"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="10" Padding="20,12">
                        <!-- Header with Icon and Title -->
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                            <TextBlock x:Name="ExpandedIcon" 
                                       Text="▶" 
                                       Foreground="#00D084" 
                                       FontSize="14" 
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ExpandedTitle" 
                                       Text="Playing" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Main Content -->
                        <TextBlock x:Name="ExpandedText" 
                                   Text="Eminem - Lose Yourself" 
                                   Foreground="#CCCCCC" 
                                   FontSize="11" 
                                   TextWrapping="Wrap"
                                   MaxHeight="30"/>

                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="PlayPauseBtn" 
                                    Content="⏸" 
                                    Background="Transparent" 
                                    Foreground="White" 
                                    FontSize="14" 
                                    Padding="8"
                                    Click="PlayPauseBtn_Click"
                                    BorderThickness="0"/>
                            <Button x:Name="SkipBtn" 
                                    Content="⏭" 
                                    Background="Transparent" 
                                    Foreground="White" 
                                    FontSize="14" 
                                    Padding="8"
                                    Click="SkipBtn_Click"
                                    BorderThickness="0"/>
                        </StackPanel>

                        <!-- Progress Bar -->
                        <Grid Height="2" Margin="0,4,0,4">
                            <ProgressBar x:Name="ProgressBar" 
                                         Background="#333333" 
                                         Foreground="#00D084" 
                                         IsIndeterminate="False" 
                                         Value="45"
                                         Height="2"/>
                        </Grid>

                        <!-- Time Display -->
                        <TextBlock x:Name="TimeDisplay" 
                                   Text="1:30 / 3:25" 
                                   Foreground="#888888" 
                                   FontSize="9" 
                                   TextAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- System Status Bar (Top Right) -->
        <Grid x:Name="StatusIndicator" 
              Width="Auto" 
              Height="24" 
              HorizontalAlignment="Right" 
              VerticalAlignment="Top" 
              Margin="0,10,15,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock x:Name="SignalStatus" 
                           Text="📶" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="BatteryStatus" 
                           Text="🔋" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TimeStatus" 
                           Text="12:00" 
                           Foreground="White" 
                           FontSize="11" 
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
